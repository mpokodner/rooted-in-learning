1a:["$","div",null,{"className":"legal-section","children":[["$","h2",null,{"className":"legal-section-title","children":"Assistive Technology Compatibility"}],["$","p",null,{"className":"legal-text","children":"The Rooted Learner is designed to be compatible with:"}],["$","ul",null,{"className":"legal-list","children":[["$","li",null,{"children":"Modern web browsers (Chrome, Firefox, Safari, Edge)"}],["$","li",null,{"children":"Screen readers (VoiceOver on macOS/iOS, NVDA and JAWS on Windows, TalkBack on Android)"}],["$","li",null,{"children":"Voice recognition software"}],["$","li",null,{"children":"Screen magnification tools"}],["$","li",null,{"children":"Alternative input devices"}]]}]]}]
1b:["$","div",null,{"className":"legal-section","children":[["$","h2",null,{"className":"legal-section-title","children":"Downloadable Resources"}],["$","p",null,{"className":"legal-text","children":"We make every effort to ensure our downloadable lesson plans, templates, and other educational materials are accessible. This includes:"}],["$","ul",null,{"className":"legal-list","children":[["$","li",null,{"children":"Using proper heading structures in documents"}],["$","li",null,{"children":"Adding alt text to images within downloadable resources"}],["$","li",null,{"children":"Using readable fonts and adequate text sizing"}],["$","li",null,{"children":"Providing content in commonly accessible formats (PDF, Google Docs)"}]]}],["$","p",null,{"className":"legal-text","children":["If you need a resource in an alternative format, please ",["$","$L11",null,{"href":"/contact","children":"contact us"}]," and we will do our best to accommodate your request."]}]]}]
1c:["$","div",null,{"className":"legal-section","children":[["$","h2",null,{"className":"legal-section-title","children":"Known Limitations"}],["$","p",null,{"className":"legal-text","children":"While we work hard to ensure accessibility across our entire site, we acknowledge that some areas may still need improvement. Known limitations include:"}],["$","ul",null,{"className":"legal-list","children":[["$","li",null,{"children":"Some older downloadable resources may not have full accessibility markup — we are updating these on an ongoing basis"}],["$","li",null,{"children":"Third-party embedded content (such as social media feeds or external video players) may not fully meet our accessibility standards"}],["$","li",null,{"children":"User-generated content (such as blog comments, if enabled) may not always follow accessibility best practices"}]]}],["$","p",null,{"className":"legal-text","children":"We are actively working to address these limitations and welcome your feedback to help prioritize improvements."}]]}]
