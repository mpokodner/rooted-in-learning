      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/consulting",
      "destination": "/services/consulting",
      "statusCode": 308,
      "regex": "^(?!/_next)/consulting(?:/)?$"
    },
    {
      "source": "/consulting/assessalign",
